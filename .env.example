NEXT_PUBLIC_WORDPRESS_GRAPHQL_ENDPOINT=http://eara.local/graphql
WORDPRESS_SITE_ORIGIN=https://backofficeadmin.eara.eu
NEXT_PUBLIC_WORDPRESS_SITE_ORIGIN=https://backofficeadmin.eara.eu

# Revalidation Secret (deve ser o mesmo no WordPress)
# Gere um token forte: openssl rand -base64 32
REVALIDATE_SECRET=seu_token_super_secreto_aqui_change_me

NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=eara_global
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sitemap XML proxy cache/timing
SITEMAP_REVALIDATE_SECONDS=900
SITEMAP_STALE_SECONDS=86400
SITEMAP_FETCH_TIMEOUT_MS=8000
SITEMAP_STREAM_THRESHOLD_BYTES=2097152

MAILCHIMP_API_KEY=
MAILCHIMP_SERVER=
MAILCHIMP_AUDIENCE_ID=

# JigsawStack Translation (https://jigsawstack.com/dashboard)
JIGSAWSTACK_API_KEY=

# Upstash Redis integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Translation cache tuning
TRANSLATION_CACHE_TTL_SECONDS=2592000
TRANSLATION_CHUNK_SIZE=20
TRANSLATION_CHUNK_CHAR_LIMIT=4500